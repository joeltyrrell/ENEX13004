# === ROS 2 (Colcon) Specific ===
build/
install/
log/
# Keep these if you still use ROS 1, otherwise they can stay
devel/
devel_isolated/
build_isolated/

# === Python Junk ===
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# === VS Code Surgical Rules ===
# Ignore the whole folder...
.vscode/*
# ...BUT keep your helpful config files
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
# Block the heavy 186MB database files even if they are in .vscode
*.db
*.db-shm
*.db-wal
.vscode/ipch/

# === OS & System Junk ===
.DS_Store
.directory
*~
*.swp